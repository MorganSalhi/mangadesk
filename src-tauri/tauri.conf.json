{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MangaDesk",
  "version": "0.2.0",
  "identifier": "com.mangadesk.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MangaDesk",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/mangadesk/**"]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": { "schemes": ["mangadesk"] }
    },
    "updater": {
      "endpoints": [
        "https://github.com/MorganSalhi/mangadesk/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4MjNFOUMzRTg1NjA5OEQKUldTTkNWYm93K2tqNk5KdWkwRk5ObE4ydVRmRFBEQUdLdEgybHhxYTBoYTRxVDI5am1xQnJJNkMK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
